# Jarvis Cloud Backend - Environment Variables
# Copy to .env and fill in your values

# Database (omit for SQLite fallback in development)
# DATABASE_URL=postgresql://jarvis:password@localhost:5432/jarvis_db

# Server
PORT=3001
NODE_ENV=development

# Auth (change in production!)
JWT_SECRET=change_this_in_production_to_a_long_random_string

# LLM Provider (at least one required for tax chat)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Payment (optional, mock mode if not set)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# External Tax AI (optional, LLM fallback used if not set)
TAX_API_URL=
TAX_API_KEY=

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:18789,http://localhost:3000
