{
  "name": "@jarvis-tax/sdk",
  "version": "1.0.0",
  "description": "Official SDK for the Jarvis Tax Assistant API. Query Indian tax laws, analyze documents, track compliance, and look up customs tariffs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "jarvis",
    "tax",
    "gst",
    "income-tax",
    "customs",
    "india",
    "compliance",
    "ai",
    "assistant",
    "sdk"
  ],
  "author": "Jarvis Tax Assistant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jarvis-tax/jarvis.git",
    "directory": "sdk"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
